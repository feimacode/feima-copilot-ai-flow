{
  "name": "copilot-ai-flow",
  "displayName": "AI Flow - Multi-Agent Orchestration",
  "description": "Multi-role AI orchestration in VS Code — pipeline, iterative, & fork-join workflows with built-in flows for code review, sprint planning, and incident response",
  "version": "0.1.5",
  "publisher": "feima",
  "license": "MIT",
  "icon": "assets/icon.png",
  "galleryBanner": {
    "color": "#1e1e2e",
    "theme": "dark"
  },
  "homepage": "https://flow-docs.feimacode.com",
  "bugs": "https://github.com/feimacode/feima-copilot-ai-flow/issues",
  "badges": [
    {
      "url": "https://img.shields.io/github/license/feimacode/feima-copilot-ai-flow",
      "href": "https://github.com/feimacode/feima-copilot-ai-flow/blob/main/LICENSE",
      "description": "MIT License"
    }
  ],
  "pricing": "Free",
  "engines": {
    "vscode": "^1.85.0",
    "node": ">=22.0.0"
  },
  "categories": [
    "AI",
    "Chat"
  ],
  "keywords": [
    "copilot",
    "ai",
    "chat",
    "flow",
    "orchestration",
    "workflow",
    "automation",
    "multi-agent",
    "pipeline",
    "code-review",
    "yaml",
    "prompt",
    "agent",
    "incident-response",
    "sprint-planning"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/feimacode/feima-copilot-ai-flow"
  },
  "extensionPack": [
    "feima.copilot-more-llms"
  ],
  "extensionDependencies": [
    "github.copilot-chat"
  ],
  "activationEvents": [
    "onLanguageModel:*",
    "onLanguage:yaml"
  ],
  "enabledApiProposals": [
    "chatSessionsProvider",
    "chatParticipantPrivate",
    "chatPromptFiles",
    "chatParticipantAdditions"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "chatParticipants": [
      {
        "id": "feima.copilot-ai-flow",
        "name": "flow",
        "description": "Orchestrate multiple AI roles in a single command — pipeline, iterative, or fork-join execution with tool use and context injection",
        "isSticky": true,
        "commands": [
          {
            "name": "search",
            "description": "Search for flows in the built-in library by name, tag, or category",
            "sampleRequest": "openspec refactoring"
          },
          {
            "name": "list",
            "description": "List all available flows grouped by category"
          },
          {
            "name": "browse",
            "description": "Browse the flow gallery with details",
            "isSticky": true
          },
          {
            "name": "install",
            "description": "Copy a built-in flow to your workspace",
            "sampleRequest": "sdd-spec-kit"
          },
          {
            "name": "tutorial",
            "description": "Browse the built-in tutorial pages for flow authoring and concepts"
          },
          {
            "name": "create",
            "description": "Create a new flow from a natural language description",
            "sampleRequest": "a code review with separate security and style lenses"
          },
          {
            "name": "enhance",
            "description": "Enhance an existing flow with new capabilities",
            "sampleRequest": "--add-jira-integration"
          },
          {
            "name": "refresh",
            "description": "Refresh the flow catalog from GitHub"
          },
          {
            "name": "status",
            "description": "Show catalog health and metadata"
          },
          {
            "name": "gallery",
            "description": "Open the Flow Gallery UI as an editor panel"
          }
        ]
      }
    ],
    "commands": [
      {
        "command": "feima.copilot-ai-flow.browse",
        "title": "Open Flow Gallery",
        "category": "AI Flow",
        "icon": "$(library)"
      },
      {
        "command": "feima.copilot-ai-flow.search",
        "title": "Search Prompts",
        "category": "AI Flow",
        "icon": "$(search)"
      },
      {
        "command": "feima.copilot-ai-flow.usePrompt",
        "title": "Use Prompt",
        "category": "AI Flow"
      },
      {
        "command": "feima.copilot-ai-flow.copyToWorkspace",
        "title": "Copy Prompt to Workspace",
        "category": "AI Flow"
      },
      {
        "command": "feima.copilot-ai-flow.createFromTemplate",
        "title": "Create Prompt from Template",
        "category": "AI Flow",
        "icon": "$(add)"
      },
      {
        "command": "feima.copilot-ai-flow.installCategory",
        "title": "Install Category to Workspace",
        "category": "AI Flow"
      },
      {
        "command": "feima.copilot-ai-flow.listTools",
        "title": "List Available Tools",
        "category": "AI Flow",
        "icon": "$(tools)"
      },
      {
        "command": "feima.copilot-ai-flow.openVisualEditor",
        "title": "Open Visual Editor",
        "category": "AI Flow",
        "icon": "$(preview)"
      },
      {
        "command": "feima.copilot-ai-flow.openTextEditor",
        "title": "Open Text Editor",
        "category": "AI Flow",
        "icon": "$(go-to-file)"
      },
      {
        "command": "feima.copilot-ai-flow.toggleEditor",
        "title": "Toggle Editor",
        "category": "AI Flow",
        "icon": "$(compare-changes)"
      },
      {
        "command": "feima.copilot-ai-flow.runFlow",
        "title": "Run Flow",
        "category": "AI Flow",
        "icon": "$(play)"
      },
      {
        "command": "feima.copilot-ai-flow.tutorialPage",
        "title": "Open Tutorial Page",
        "category": "AI Flow"
      },
      {
        "command": "feima.copilot-ai-flow.installAndRun",
        "title": "Install and Run Flow",
        "category": "AI Flow"
      },
      {
        "command": "feima.copilot-ai-flow.installAndOpen",
        "title": "Install and Open Flow",
        "category": "AI Flow"
      },
      {
        "command": "feima.copilot-ai-flow.openGalleryFlow",
        "title": "Open Flow from Gallery",
        "category": "AI Flow"
      }
    ],
    "keybindings": [
      {
        "command": "feima.copilot-ai-flow.runFlow",
        "key": "ctrl+shift+r",
        "when": "editorFocus && resourceFilename =~ /\\.flow\\.ya?ml$/ && !notebookEditorFocused"
      },
      {
        "command": "feima.copilot-ai-flow.openVisualEditor",
        "key": "ctrl+shift+v",
        "when": "editorFocus && resourceFilename =~ /\\.flow\\.ya?ml$/ && !notebookEditorFocused"
      },
      {
        "command": "feima.copilot-ai-flow.toggleEditor",
        "key": "ctrl+k v",
        "when": "!terminalFocus && ((editorFocus && resourceFilename =~ /\\.flow\\.ya?ml$/ && !notebookEditorFocused) || activeCustomEditorId == 'feima.copilot-ai-flow.flowEditor')"
      }
    ],
    "languages": [
      {
        "id": "yaml",
        "extensions": [
          ".flow.yaml",
          ".flow.yml"
        ],
        "aliases": [
          "Flow",
          "flow"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "completionProviders": [
      {
        "language": "yaml",
        "triggerCharacters": [
          "-",
          ":",
          " "
        ],
        "provideCompletionItems": "feima.copilot-ai-flow.toolsCompletion"
      },
      {
        "language": "yaml",
        "triggerCharacters": [
          "-",
          ":",
          " "
        ],
        "provideCompletionItems": "feima.copilot-ai-flow.agentsCompletion"
      },
      {
        "language": "yaml",
        "triggerCharacters": [
          "-",
          ":",
          " "
        ],
        "provideCompletionItems": "feima.copilot-ai-flow.promptsCompletion"
      }
    ],
    "yamlValidation": [
      {
        "fileMatch": [
          "*.flow.yaml",
          "*.flow.yml"
        ],
        "url": "./schemas/flow.schema.json"
      }
    ],
    "customEditors": [
      {
        "viewType": "feima.copilot-ai-flow.flowEditor",
        "displayName": "Flow Editor",
        "selector": [
          {
            "filenamePattern": "*.flow.yaml"
          },
          {
            "filenamePattern": "*.flow.yml"
          }
        ],
        "priority": "option"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "feima.copilot-ai-flow.runFlow",
          "when": "resourceFilename =~ /\\.flow\\.ya?ml$/ && !notebookEditorFocused",
          "group": "navigation"
        },
        {
          "command": "feima.copilot-ai-flow.openVisualEditor",
          "when": "resourceFilename =~ /\\.flow\\.ya?ml$/ && !notebookEditorFocused && activeCustomEditorId != 'feima.copilot-ai-flow.flowEditor'",
          "group": "navigation"
        },
        {
          "command": "feima.copilot-ai-flow.openTextEditor",
          "when": "activeCustomEditorId == 'feima.copilot-ai-flow.flowEditor'",
          "group": "navigation"
        }
      ],
      "explorer/context": [
        {
          "command": "feima.copilot-ai-flow.openVisualEditor",
          "when": "resourceFilename =~ /\\.flow\\.ya?ml$/",
          "group": "navigation"
        }
      ],
      "editor/title/context": [
        {
          "command": "feima.copilot-ai-flow.openVisualEditor",
          "when": "resourceFilename =~ /\\.flow\\.ya?ml$/",
          "group": "1_open"
        }
      ]
    },
    "configuration": {
      "title": "AI Flow",
      "properties": {
        "aiFlow.maxToolRounds": {
          "type": "number",
          "default": 100,
          "minimum": 1,
          "maximum": 500,
          "description": "Maximum tool-calling loop iterations per role before the engine stops and reports the result."
        },
        "aiFlow.maxToolCount": {
          "type": "number",
          "default": 128,
          "minimum": 1,
          "maximum": 128,
          "description": "Maximum number of tools sent to the LLM. When exceeded, smart filtering keeps the most relevant tools."
        },
        "aiFlow.flowMatch.confidenceThreshold": {
          "type": "number",
          "default": 0.8,
          "minimum": 0,
          "maximum": 1,
          "description": "Score threshold (0.0–1.0) above which a flow match auto-executes without confirmation."
        },
        "aiFlow.flowMatch.minScore": {
          "type": "number",
          "default": 0.5,
          "minimum": 0,
          "maximum": 1,
          "description": "Minimum score (0.0–1.0) to include a flow match in the results list."
        },
        "aiFlow.maxGenerationRetries": {
          "type": "number",
          "default": 3,
          "minimum": 1,
          "maximum": 10,
          "description": "Maximum retry rounds when the LLM produces invalid YAML during /create or /enhance."
        },
        "aiFlow.toolInvokeTokenBudget": {
          "type": "number",
          "default": 4000,
          "minimum": 100,
          "maximum": 16000,
          "description": "Token budget reserved for tool invocation result content."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./ && node esbuild.webview.mjs",
    "compile:webview": "node esbuild.webview.mjs",
    "watch": "tsc -watch -p ./",
    "watch:webview": "node esbuild.webview.mjs --watch",
    "pretest": "npm run compile",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --ext ts",
    "package": "vsce package --allow-star-activation",
    "build:vsix": "tsx build/build.ts"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^18.x",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "@vscode/vsce": "^2.22.0",
    "@xyflow/react": "^12.3.6",
    "esbuild": "^0.25.0",
    "eslint": "^8.56.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "tsx": "^4.22.4",
    "typescript": "^5.3.0",
    "vitest": "^1.6.1"
  },
  "dependencies": {
    "@github/copilot": "^1.0.54",
    "@vscode/prompt-tsx": "^0.4.0-alpha.5",
    "js-yaml": "^4.1.0"
  }
}
