{
  "name": "copilot-ai-flow",
  "displayName": "Feima Copilot AI Flow",
  "description": "Multi-perspective AI discussions with configurable expert roles",
  "version": "0.1.0",
  "publisher": "feima",
  "icon": "assets/icon.png",
  "engines": {
    "vscode": "^1.85.0",
    "node": ">=22.0.0"
  },
  "categories": [
    "AI",
    "Chat",
    "Education"
  ],
  "keywords": [
    "copilot",
    "ai",
    "chat",
    "flow",
    "discussion",
    "multi-role",
    "collaboration"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/feimacode/feima-copilot-ai-flow"
  },
  "activationEvents": [
    "onLanguageModel:*"
  ],
  "enabledApiProposals": [
    "chatSessionsProvider",
    "chatParticipantPrivate",
    "chatPromptFiles",
    "chatParticipantAdditions"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "chatParticipants": [
      {
        "id": "feima.copilot-ai-flow",
        "name": "flow",
        "description": "Multi-perspective AI discussions with expert roles",
        "isSticky": true,
        "commands": [
          {
            "name": "search",
            "description": "Search for flows in the built-in library by name, tag, or category",
            "sampleRequest": "openspec refactoring"
          },
          {
            "name": "list",
            "description": "List all available flows grouped by category"
          },
          {
            "name": "browse",
            "description": "Browse the flow gallery with details",
            "isSticky": true
          },
          {
            "name": "install",
            "description": "Copy a built-in flow to your workspace",
            "sampleRequest": "sdd-spec-kit"
          }
        ]
      }
    ],
    "commands": [
      {
        "command": "feima.copilot-ai-flow.browse",
        "title": "Open Flow Gallery",
        "category": "AI Flow",
        "icon": "$(library)"
      },
      {
        "command": "feima.copilot-ai-flow.search",
        "title": "Search Prompts",
        "category": "AI Flow",
        "icon": "$(search)"
      },
      {
        "command": "feima.copilot-ai-flow.usePrompt",
        "title": "Use Prompt",
        "category": "AI Flow"
      },
      {
        "command": "feima.copilot-ai-flow.copyToWorkspace",
        "title": "Copy Prompt to Workspace",
        "category": "AI Flow"
      },
      {
        "command": "feima.copilot-ai-flow.createFromTemplate",
        "title": "Create Prompt from Template",
        "category": "AI Flow",
        "icon": "$(add)"
      },
      {
        "command": "feima.copilot-ai-flow.installCategory",
        "title": "Install Category to Workspace",
        "category": "AI Flow"
      },
      {
        "command": "feima.copilot-ai-flow.listTools",
        "title": "List Available Tools",
        "category": "AI Flow",
        "icon": "$(tools)"
      },
      {
        "command": "feima.copilot-ai-flow.openVisualEditor",
        "title": "Open Visual Editor",
        "category": "AI Flow",
        "icon": "$(preview)"
      },
      {
        "command": "feima.copilot-ai-flow.toggleEditor",
        "title": "Toggle Editor",
        "category": "AI Flow",
        "icon": "$(compare-changes)"
      }
    ],
    "keybindings": [
      {
        "command": "feima.copilot-ai-flow.openVisualEditor",
        "key": "ctrl+shift+e"
      },
      {
        "command": "feima.copilot-ai-flow.toggleEditor",
        "key": "ctrl+k e",
        "when": "resourceExtname =~ /\\.flow\\.ya?ml$/"
      }
    ],
    "languages": [
      {
        "id": "yaml",
        "extensions": [".flow.yaml", ".flow.yml"],
        "aliases": ["Flow", "flow"],
        "configuration": "./language-configuration.json"
      }
    ],
    "completionProviders": [
      {
        "language": "yaml",
        "triggerCharacters": ["-", ":", " "],
        "provideCompletionItems": "feima.copilot-ai-flow.toolsCompletion"
      },
      {
        "language": "yaml",
        "triggerCharacters": ["-", ":", " "],
        "provideCompletionItems": "feima.copilot-ai-flow.agentsCompletion"
      },
      {
        "language": "yaml",
        "triggerCharacters": ["-", ":", " "],
        "provideCompletionItems": "feima.copilot-ai-flow.promptsCompletion"
      }
    ],
    "yamlValidation": [
      {
        "fileMatch": ["*.flow.yaml", "*.flow.yml"],
        "url": "./schemas/flow.schema.json"
      }
    ],
    "customEditors": [
      {
        "viewType": "feima.copilot-ai-flow.flowEditor",
        "displayName": "Flow Editor",
        "selector": [
          { "filenamePattern": "*.flow.yaml" },
          { "filenamePattern": "*.flow.yml" }
        ],
        "priority": "option"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./ && node esbuild.webview.mjs",
    "compile:webview": "node esbuild.webview.mjs",
    "watch": "tsc -watch -p ./",
    "watch:webview": "node esbuild.webview.mjs --watch",
    "pretest": "npm run compile",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --ext ts",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^18.x",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "@vscode/vsce": "^2.22.0",
    "@xyflow/react": "^12.3.6",
    "esbuild": "^0.25.0",
    "eslint": "^8.56.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "typescript": "^5.3.0",
    "vitest": "^1.6.1"
  },
  "dependencies": {
    "@github/copilot": "^1.0.54",
    "@vscode/prompt-tsx": "^0.4.0-alpha.5",
    "js-yaml": "^4.1.0"
  }
}
